NODE_ENV=development
PORT=3000
DATABASE_PATH=data/timeoff.sqlite
DATABASE_SYNCHRONIZE=true
JWT_SECRET=change-me-in-prod-please
JWT_EXPIRES_IN=1h
HCM_BASE_URL=http://localhost:3100
HCM_TIMEOUT_MS=5000
HCM_MAX_RETRIES=3
HCM_RETRY_BASE_MS=100
HCM_CIRCUIT_FAILURE_THRESHOLD=5
HCM_CIRCUIT_COOLDOWN_MS=30000
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_WORKER_ENABLED=true
RECONCILE_CRON_ENABLED=false
RECONCILE_CRON_EXPRESSION=0 */15 * * * *
HCM_BATCH_INGEST_SECRET=batch-ingest-shared-secret
